{
  "name": "mc-account-manager",
  "version": "1.0.0",
  "description": "MC Account Database Manager",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:electron\"",
    "dev:ui": "vite",
    "dev:electron": "wait-on tcp:5123 && tsc -p electron/tsconfig.json && electron .",
    "build": "npm run build:ui && npm run build:electron && electron-builder",
    "build:ui": "tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "appId": "com.mc.accountmanager",
    "productName": "MC Account Manager",
    "directories": {
      "output": "release/"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3/build/Release/better_sqlite3.node",
        "to": "better_sqlite3.node"
      }
    ]
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "skinview3d": "^3.4.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.2.13",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.8.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.1",
    "electron-builder": "^25.1.5",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
